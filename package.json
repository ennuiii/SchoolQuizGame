{
  "name": "school-quiz-game",
  "version": "1.0.0",
  "private": true,
  "description": "Multiplayer educational game for German school system",
  "main": "server/index.js",
  "proxy": "http://localhost:5000",
  "scripts": {
    "start": "node server/index.js",
    "dev:client": "react-scripts start",
    "dev:server": "cd server && node index.js",
    "dev:admin": "cd admin-panel && npm start",
    "build": "npm run render-build",
    "install-all": "npm install && cd admin-panel && npm install",
    "dev": "concurrently \"npm run start\" \"cd admin-panel && npm start\"",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "render-build": "NODE_OPTIONS='--openssl-legacy-provider' CI=false TSC_COMPILE_ON_ERROR=true react-scripts build && mkdir -p server/build && cp -r build/* server/build/ && cd server && npm install --legacy-peer-deps",
    "render-start": "node server/index.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.3",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "ajv": "^6.12.4",
    "ajv-keywords": "^3.5.2",
    "bootstrap": "^5.3.2",
    "dotenv": "^16.5.0",
    "fabric": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.7.2",
    "uuid": "^9.0.0",
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "cors": "^2.8.5",
    "typescript": "4.8.4"
  },
  "devDependencies": {
    "@types/fabric": "^5.3.10",
    "@types/node": "^16.18.0",
    "@types/uuid": "^9.0.1",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": "18.17.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
